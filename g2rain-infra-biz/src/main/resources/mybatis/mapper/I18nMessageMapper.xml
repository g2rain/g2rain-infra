<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.g2rain.infra.dao.I18nMessageDao">
    <!-- 通用结果集映射（包含所有字段：主键+基础字段+业务字段） -->
    <resultMap id="BaseResultMap" type="com.g2rain.infra.dao.po.I18nMessagePo">
        <!-- 主键字段 -->
        <id column="id" property="id" jdbcType="BIGINT"/>
        <!-- 基础字段（createTime、updateTime） -->
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <!-- 业务字段（其他自定义字段） -->
        <result column="message_usage_id" property="messageUsageId" jdbcType="BIGINT"/>
        <result column="language_code" property="languageCode" jdbcType="VARCHAR"/>
        <result column="region_code" property="regionCode" jdbcType="VARCHAR"/>
        <result column="message_code" property="messageCode" jdbcType="VARCHAR"/>
        <result column="message_text" property="messageText" jdbcType="LONGVARCHAR"/>
        <result column="extend_field" property="extendField" jdbcType="LONGVARCHAR"/>
        <!-- version字段（如果存在） -->
        <result column="version" property="version" jdbcType="INTEGER"/>
    </resultMap>

    <!-- 定义可复用排序方向片段 -->
    <sql id="directionClause">
        <choose>
            <when test="item.direction == 'DESC'">DESC</when>
            <otherwise>ASC</otherwise>
        </choose>
    </sql>

    <!-- 可复用的动态排序 SQL 片段 -->
    <sql id="dynamicOrderBy">
        <trim prefix="ORDER BY" suffixOverrides=",">
            <foreach collection="safeSorts" item="item" separator=",">
                <choose>
                    <when test="item.column == 'id'">
                        id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'createTime'">
                        create_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'updateTime'">
                        update_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'messageUsageId'">
                        message_usage_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'languageCode'">
                        language_code
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'regionCode'">
                        region_code
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'messageCode'">
                        message_code
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'messageText'">
                        message_text
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'extendField'">
                        extend_field
                        <include refid="directionClause"/>
                    </when>
                </choose>
            </foreach>
        </trim>
    </sql>

    <!-- 插入单条记录 -->
    <insert id="insert" parameterType="com.g2rain.infra.dao.po.I18nMessagePo">
        INSERT INTO i18n_message (
        <!-- 主键字段（自增主键不包含在插入语句中） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        message_usage_id, language_code, region_code, message_code, message_text, extend_field,
        <!-- version字段（如果存在） -->
        version
        ) VALUES (
        <!-- 主键值（自增主键不包含） -->
        #{id, jdbcType=BIGINT},
        <!-- 基础字段值 -->
        #{createTime, jdbcType=TIMESTAMP}, #{updateTime, jdbcType=TIMESTAMP},
        <!-- 业务字段值 -->
        #{messageUsageId, jdbcType=BIGINT}, #{languageCode, jdbcType=VARCHAR}, #{regionCode, jdbcType=VARCHAR}, #{messageCode, jdbcType=VARCHAR}, #{messageText, jdbcType=LONGVARCHAR}, #{extendField, jdbcType=LONGVARCHAR},
        <!-- version字段值（如果存在，设置默认值为0） -->
        0
        )
    </insert>

    <!-- 批量插入记录 -->
    <insert id="insertMultiple" parameterType="java.util.List">
        INSERT INTO i18n_message (
        <!-- 主键字段（自增主键不包含） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        message_usage_id, language_code, region_code, message_code, message_text, extend_field,
        <!-- version字段（如果存在） -->
        version
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
            <!-- 主键值（自增主键不包含） -->
            #{item.id, jdbcType=BIGINT},
            <!-- 基础字段值 -->
            #{item.createTime, jdbcType=TIMESTAMP}, #{item.updateTime, jdbcType=TIMESTAMP},
            <!-- 业务字段值 -->
            #{item.messageUsageId, jdbcType=BIGINT}, #{item.languageCode, jdbcType=VARCHAR}, #{item.regionCode, jdbcType=VARCHAR}, #{item.messageCode, jdbcType=VARCHAR}, #{item.messageText, jdbcType=LONGVARCHAR}, #{item.extendField, jdbcType=LONGVARCHAR},
            <!-- version字段值（如果存在，设置默认值为0） -->
            0
            )
        </foreach>
    </insert>

    <!-- 根据ID更新记录（包含基础字段和业务字段） -->
    <update id="update" parameterType="com.g2rain.infra.dao.po.I18nMessagePo">
        UPDATE i18n_message
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="messageUsageId != null">
                message_usage_id = #{messageUsageId, jdbcType=BIGINT},
            </if>
            <if test="languageCode != null">
                language_code = #{languageCode, jdbcType=VARCHAR},
            </if>
            <if test="regionCode != null">
                region_code = #{regionCode, jdbcType=VARCHAR},
            </if>
            <if test="messageCode != null">
                message_code = #{messageCode, jdbcType=VARCHAR},
            </if>
            <if test="messageText != null">
                message_text = #{messageText, jdbcType=LONGVARCHAR},
            </if>
            <if test="extendField != null">
                extend_field = #{extendField, jdbcType=LONGVARCHAR},
            </if>
            <!-- version字段更新（如果存在，版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
    </update>

    <!-- 根据ID和Version更新记录（乐观锁更新，包含基础字段和业务字段） -->
    <update id="updateByVersion" parameterType="com.g2rain.infra.dao.po.I18nMessagePo">
        UPDATE i18n_message
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="messageUsageId != null">
                message_usage_id = #{messageUsageId, jdbcType=BIGINT},
            </if>
            <if test="languageCode != null">
                language_code = #{languageCode, jdbcType=VARCHAR},
            </if>
            <if test="regionCode != null">
                region_code = #{regionCode, jdbcType=VARCHAR},
            </if>
            <if test="messageCode != null">
                message_code = #{messageCode, jdbcType=VARCHAR},
            </if>
            <if test="messageText != null">
                message_text = #{messageText, jdbcType=LONGVARCHAR},
            </if>
            <if test="extendField != null">
                extend_field = #{extendField, jdbcType=LONGVARCHAR},
            </if>
            <!-- version字段更新（乐观锁版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        AND version = #{version, jdbcType=INTEGER}
    </update>

    <!-- 根据ID删除记录（物理删除记录） -->
    <delete id="delete" parameterType="Long">
        DELETE FROM i18n_message
        WHERE id = #{id, jdbcType=BIGINT}
    </delete>

    <!-- 根据ID查询记录（查询所有字段） -->
    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        message_usage_id, language_code, region_code, message_code, message_text, extend_field,
        <!-- version字段（如果存在） -->
        version
        FROM i18n_message
        WHERE id = #{id, jdbcType=BIGINT}
    </select>

    <!-- 根据SelectDto条件查询列表 -->
    <select id="selectList" parameterType="com.g2rain.infra.dto.I18nMessageSelectDto" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        message_usage_id, language_code, region_code, message_code, message_text, extend_field,
        <!-- version字段（如果存在） -->
        version
        FROM i18n_message
        <where>
            <!-- 主键筛选 -->
            <if test="id != null">
                AND id = #{id, jdbcType=BIGINT}
            </if>
            <if test="ids != null and ids.size() > 0">
                AND id IN
                <foreach collection="ids" item="item" open="(" separator="," close=")">
                    #{item, jdbcType=BIGINT}
                </foreach>
            </if>
            <!-- 基础字段筛选（createTime和updateTime时间筛选） -->
            <if test="createTime != null">
                <if test="createTime[0] != '' and (createTime.size() lt 2 or createTime[1] == '')">
                    AND create_time >= #{createTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] == '' and createTime[1] != ''">
                    AND create_time &lt;= #{createTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] != '' and createTime[1] != ''">
                    AND create_time BETWEEN #{createTime[0], jdbcType=TIMESTAMP}
                    AND #{createTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <if test="updateTime != null">
                <if test="updateTime[0] != '' and (updateTime.size() lt 2 or updateTime[1] == '')">
                    AND update_time >= #{updateTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] == '' and updateTime[1] != ''">
                    AND update_time &lt;= #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] != '' and updateTime[1] != ''">
                    AND update_time BETWEEN #{updateTime[0], jdbcType=TIMESTAMP}
                    AND #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <!-- 业务字段筛选 -->
            <if test="messageUsageId != null">
                AND message_usage_id = #{messageUsageId, jdbcType=BIGINT}
            </if>
            <if test="languageCode != null">
                AND language_code = #{languageCode, jdbcType=VARCHAR}
            </if>
            <if test="regionCode != null">
                AND region_code = #{regionCode, jdbcType=VARCHAR}
            </if>
            <if test="messageCode != null">
                AND message_code = #{messageCode, jdbcType=VARCHAR}
            </if>
            <if test="messageText != null">
                AND message_text = #{messageText, jdbcType=LONGVARCHAR}
            </if>
            <if test="extendField != null">
                AND extend_field = #{extendField, jdbcType=LONGVARCHAR}
            </if>
        </where>
        <include refid="dynamicOrderBy"/>
    </select>
</mapper>
