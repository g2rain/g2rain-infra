<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- 请求级 DEBUG 放行开关：当 MDC[DEBUG_PRINT_LEVEL]=TRUE 时，允许日志事件通过 -->
    <turboFilter class="ch.qos.logback.classic.turbo.MDCFilter">
        <MDCKey>DEBUG_PRINT_LEVEL</MDCKey>
        <Value>TRUE</Value>
        <OnMatch>ACCEPT</OnMatch>
        <OnMismatch>NEUTRAL</OnMismatch>
    </turboFilter>

    <!-- ==========================
         1. 基础属性定义
         ========================== -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="g2rain-infra"/>
    <springProperty scope="context" name="LOG_PATH" source="LOG_PATH" defaultValue="./logs"/>
    <springProperty scope="context" name="ACTIVE_PROFILE" source="spring.profiles.active" defaultValue="dev"/>
    <!-- 控制台输出格式 -->
    <springProperty scope="context" name="CONSOLE_PATTERN"
                    source="logging.pattern.console"
                    defaultValue="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-}] [%X{spanId:-}] [%X{requestId:-}] %logger{36} - %msg%n"/>
    <!-- 文件输出格式 -->
    <springProperty scope="context" name="FILE_PATTERN"
                    source="logging.pattern.file"
                    defaultValue="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-}] [%X{spanId:-}] [%X{requestId:-}] %logger{50} - %msg%n"/>

    <!-- ==========================
         2. 控制台 Appender
         ========================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==========================
         3. 框架日志级别
         ========================== -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.apache.ibatis" level="INFO"/>

    <!-- 业务日志 -->
    <logger name="com.g2rain" level="DEBUG"/>

    <!-- ==========================
         4. 环境感知输出
         ========================== -->

    <!-- ✅ 开发环境：仅控制台 -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ✅ 非开发环境：控制台 + 文件 -->
    <springProfile name="!dev">
        <!-- ==========================
             5. 文件输出 Appender（仅非dev启用）
             ========================== -->

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${APP_NAME}.log</file>
            <encoder>
                <pattern>${FILE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>

            <!-- 按天 + 按大小滚动（推荐方式：SizeAndTimeBasedRollingPolicy） -->
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxHistory>30</maxHistory>
                <maxFileSize>100MB</maxFileSize>
            </rollingPolicy>
        </appender>

        <!-- 异步包装，提升性能 -->
        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="FILE"/>
            <queueSize>10240</queueSize>
            <discardingThreshold>0</discardingThreshold>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
    </springProfile>

</configuration>
